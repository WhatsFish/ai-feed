# Project root .env, consumed by docker-compose for the `web` service.
# Copy to .env and fill in.

# --- Auth.js (NextAuth) ---
AUTH_SECRET=                 # openssl rand -base64 32
AUTH_GITHUB_ID=              # GitHub OAuth App client id
AUTH_GITHUB_SECRET=          # GitHub OAuth App client secret
AUTH_TRUST_HOST=true         # required behind nginx reverse proxy

# --- Azure AI Foundry (live translate / interpret) ---
AZURE_AI_BASE_URL=           # e.g. https://<resource>.services.ai.azure.com/models
AZURE_AI_API_KEY=
AZURE_AI_MODEL=              # e.g. gpt-4o-mini
