# Project root .env, consumed by docker-compose for the `web` service.
# Copy to .env and fill in.

# --- Auth.js (NextAuth) ---
AUTH_SECRET=                 # openssl rand -base64 32
AUTH_GITHUB_ID=              # GitHub OAuth App client id
AUTH_GITHUB_SECRET=          # GitHub OAuth App client secret
AUTH_TRUST_HOST=true         # required behind nginx reverse proxy
AUTH_URL=                    # e.g. http://<host>/feed/api/auth — must match the
                             # GitHub OAuth App callback (with /feed/api/auth path)

# --- Azure AI Foundry (live translate / interpret) ---
# Auth is via host-VM managed identity (no API key). The VM must have a
# system-assigned identity with Cognitive Services User role on the Foundry
# resource. Same setup as ai-playground.
AZURE_AI_ENDPOINT=           # e.g. https://<resource>.services.ai.azure.com/openai/v1
AZURE_AI_DEFAULT_MODEL=      # e.g. Llama-3.3-70B-Instruct

# --- Umami analytics (optional) ---
# Both must be set for the tracking snippet to render. NEXT_PUBLIC_ vars are
# baked into the client bundle at BUILD time — changes require a rebuild.
NEXT_PUBLIC_UMAMI_SRC=        # e.g. http://20.89.176.30:3000/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
