# Auth.js v5 (NextAuth)
AUTH_SECRET=                 # openssl rand -base64 32
AUTH_GITHUB_ID=              # GitHub OAuth App client id
AUTH_GITHUB_SECRET=          # GitHub OAuth App client secret
AUTH_TRUST_HOST=true         # required when behind nginx reverse proxy

# Where the agent's digests live (mounted read-only into the container)
DIGEST_DIR=/data/digest

# Azure AI Foundry — used for live translate/interpret features
# Compatible with the OpenAI SDK by setting baseURL.
AZURE_AI_BASE_URL=           # e.g. https://<resource>.services.ai.azure.com/models
AZURE_AI_API_KEY=            # AI Foundry API key
AZURE_AI_MODEL=              # e.g. gpt-4o-mini, llama-3.3-70b-instruct
